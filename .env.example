# Copy to .env and fill in real values from your secrets manager.
# .env is gitignored.
#
# These names are scoped to docker-compose.yml. The MYSQL_EH_SERVICE_PASSWORD
# value is forwarded into the eventhorizon container as
# FVP_MYSQL_SERVICE_PASSWORD (a name chosen by examples/config/eventhorizon.yaml
# via ${ENV:FVP_MYSQL_SERVICE_PASSWORD}). The gateway has NO connector-
# specific env vars of its own; the config file controls everything.

# Operator-owned (mysql container init)
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_EH_ADMIN_PASSWORD=changeme_admin

# Application's mysql identity — gets passed through to the gateway container
# as FVP_MYSQL_SERVICE_PASSWORD for the example config file to look up.
MYSQL_EH_SERVICE_PASSWORD=changeme_service

# Gateway logging (standard tracing-subscriber env-filter).
RUST_LOG=info,eh=debug
