# Copy to .env and fill in real values from your secrets manager.
# .env is gitignored.

# ============================================================================
# Postgres CONTROL plane — EventHorizon's own schema. The source of truth is
# db/postgres/schema.sql; at first container init the entrypoint applies
# schema.sql and then zz_set_role_passwords.sh attaches the passwords below
# to the eh_admin and eh_service roles.
# ============================================================================
POSTGRES_ROOT_PASSWORD=changeme_pg_root
EH_ADMIN_PASSWORD=changeme_eh_admin
EH_SERVICE_PASSWORD=changeme_eh_service

# ============================================================================
# MySQL — a connector backend (one kind among many). The
# MYSQL_EH_SERVICE_PASSWORD value is forwarded into the eventhorizon container
# as FVP_MYSQL_SERVICE_PASSWORD (a name chosen by
# examples/config/eventhorizon.yaml via ${ENV:FVP_MYSQL_SERVICE_PASSWORD}).
# The gateway has NO connector-specific env vars of its own; the config file
# controls everything.
# ============================================================================
MYSQL_ROOT_PASSWORD=changeme_mysql_root
MYSQL_EH_ADMIN_PASSWORD=changeme_mysql_admin
MYSQL_EH_SERVICE_PASSWORD=changeme_mysql_service

# Gateway logging (standard tracing-subscriber env-filter).
RUST_LOG=info,eh=debug
